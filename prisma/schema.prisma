generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


model Wish {
  id        String   @id @default(cuid())
  name      String
  message   String?  @db.Text
  isGifted  Boolean  @default(false)
  amount    Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RSVP {
  id        String   @id @default(cuid())
  name      String
  guests    String
  message   String?  @db.Text
  createdAt DateTime @default(now())
}


